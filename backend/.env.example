# Allowed CORS origins for the frontend
CORS_ORIGINS=["http://localhost:5173"]

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://localchat:localchat@localhost:5432/localchat

# Ollama (running on the host)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# IANA timezone for the agent's date/time context (e.g. UTC, Europe/Berlin)
AGENT_TIMEZONE=UTC
# Set to false to block outbound DuckDuckGo search from the API
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
